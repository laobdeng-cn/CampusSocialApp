          recipientIds: [activity.createdBy._id || activity.createdBy],
          activity,
          title: '新增报名',
          firstLine: `${request.user.name} 报名了「${activity.title}」`,
          secondLine: `当前已报名 ${activity.enrolled} 人`,
          action: 'activity_enrollment_new',
          actor: request.user._id,
