        ? request.body.pinned
        : !request.group.pinnedDiscussionIds.some(
            (item) => String(item) === String(post._id)
          );

      if (pinned) {
        await Group.updateOne(
          { _id: request.group._id },
          { $addToSet: { pinnedDiscussionIds: post._id } }
        );
      } else {
        await Group.updateOne(
          { _id: request.group._id },
          { $pull: { pinnedDiscussionIds: post._id } }
        );
