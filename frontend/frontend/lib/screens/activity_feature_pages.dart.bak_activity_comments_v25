String _activityStatusLabelFor(CampusActivity activity) {
  if (activity.isEnded) return '已结束';
  if (activity.isCheckedIn) return '已签到';
  if (activity.isCheckInAvailable) return '签到中';
  if (activity.capacity > 0 && activity.enrolled >= activity.capacity) {
    return '已满员';
  }
  if (activity.isCheckInNotStarted) return '未开始';
  return '进行中';
}

Color _activityStatusColorFor(CampusActivity activity) {
  if (activity.isEnded) return AppColors.muted;
  if (activity.isCheckedIn) return AppColors.green;
  if (activity.isCheckInAvailable) return AppColors.blue;
  if (activity.capacity > 0 && activity.enrolled >= activity.capacity) {
    return AppColors.orange;
  }
  if (activity.isCheckInNotStarted) return AppColors.purple;
  return AppColors.green;
}

Color _activityStatusBackgroundFor(CampusActivity activity) {
  return _activityStatusColorFor(activity).withValues(alpha: 0.12);
}

bool _activityIsFullFor(CampusActivity activity) {
  return activity.capacity > 0 && activity.enrolled >= activity.capacity;
}

String _activityRegisterActionText(CampusActivity activity, bool registered) {
  if (activity.isEnded) return '活动已结束';
  if (activity.isCheckedIn) return '已签到';
  if (registered) return '已报名';
  if (_activityIsFullFor(activity)) return '名额已满';
  return '立即报名';
}

bool _activityRegisterActionDisabled(CampusActivity activity, bool registered) {
  return activity.isEnded ||
      activity.isCheckedIn ||
      registered ||
      _activityIsFullFor(activity);
}

